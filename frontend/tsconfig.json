{
    "extends": "@react-native/typescript-config",
    "compilerOptions": {
        "strict": true,
        "noImplicitAny": true,
        "strictNullChecks": true,
        "esModuleInterop": true,
        "paths": {
            "@/*": [
                "./src/*"
            ]
        }
    },
    "include": [
        "src/**/*",
        "App.tsx",
        "index.js"
    ],
    "exclude": [
        "node_modules",
        "babel.config.js",
        "metro.config.js",
        "android",
        "ios"
    ]
}